{
  "version": 2,

  "functions": {
    "**/*.php": {
      "runtime": "vercel-php@0.7.3"
    }
  },

  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },

    {
      "src": "/restricted/(.*)",
      "dest": "/restricted/$1"
    },

    {
      "src": "/admin",
      "dest": "/admin.php"
    },

    {
      "src": "/login",
      "dest": "/login.php"
    },

    {
      "src": "/register",
      "dest": "/register.php"
    },

    {
      "src": "/forgot-password",
      "dest": "/forgot-password.php"
    },

    {
      "src": "/reset-password",
      "dest": "/reset-password.php"
    },

    {
      "src": "/(.*\\.css)",
      "dest": "/$1"
    },

    {
      "src": "/(.*\\.js)",
      "dest": "/$1"
    },

    {
      "src": "/(.*\\.(png|jpg|jpeg|gif|svg|webp|ico))",
      "dest": "/$1"
    },

    {
      "src": "/",
      "dest": "/index.php"
    },

    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}